__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.env
.pytest_cache/
.mypy_cache/
*.zip

# Ignore HA runtime files — these are generated by the container and should
# not be committed. The config/ directory itself IS tracked so Docker Compose
# has a place to mount, but its contents are not.
config/*
!config/.gitkeep
